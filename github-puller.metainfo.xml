<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.alihaydarsucu.GitHubPuller</id>
  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>
  <name>GitHub Puller</name>
  <summary>Batch pull GitHub repositories</summary>
  <description>
    <p>
      GitHub Puller is a modern application for batch pulling your GitHub repositories.
      Built with GTK4 and libadwaita, it provides perfect integration with GNOME desktop.
    </p>
    <p>Features:</p>
    <ul>
      <li>Modern and user-friendly interface</li>
      <li>Repository search and filtering</li>
      <li>Branch selection</li>
      <li>Private repository support (with GitHub token)</li>
      <li>Smart updates (clone/pull)</li>
      <li>Multi-repository processing</li>
      <li>Target directory selection and saving</li>
    </ul>
  </description>
  
  <launchable type="desktop-id">github-puller.desktop</launchable>
  
  <screenshots>
    <screenshot type="default">
      <caption>Main screen</caption>
      <image>https://raw.githubusercontent.com/alihaydarsucu/github-puller/main/screenshots/main.png</image>
    </screenshot>
  </screenshots>
  
  <url type="homepage">https://github.com/alihaydarsucu/github-puller</url>
  <url type="bugtracker">https://github.com/alihaydarsucu/github-puller/issues</url>
  
  <provides>
    <binary>github-puller</binary>
  </provides>
  
  <releases>
    <release version="1.0.0" date="2026-03-07">
      <description>
        <p>Initial release:</p>
        <ul>
          <li>Modern interface with GTK4 + libadwaita</li>

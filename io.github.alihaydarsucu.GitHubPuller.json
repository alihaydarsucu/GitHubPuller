{
  "id": "io.github.alihaydarsucu.GitHubPuller",
  "runtime": "org.gnome.Platform",
  "runtime-version": "49",
  "sdk": "org.gnome.Sdk",
  "command": "github-puller",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/man",
    "/share/doc",
    "/share/gtk-doc",
    "/share/man",
    "/share/pkgconfig",
    "*.la",
    "*.a"
  ],
  "modules": [
    {
      "name": "github-puller",
      "buildsystem": "simple",
      "build-commands": [
        "python3 setup.py install --prefix=${FLATPAK_DEST} --root=/ --optimize=1"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/alihaydarsucu/GitHubPuller/archive/v1.0.7.tar.gz",
          "sha256": "PLACEHOLDER",
          "strip-components": 1
        }
      ]
    }
  ]
}